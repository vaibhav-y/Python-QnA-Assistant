# Generation LLM Configuration
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_TOKENS=1024

# RAG Embedding Configuration
EMBED_MODEL=BAAI/bge-small-en-v1.5
EMBED_BATCH_SIZE=32
EMBED_CACHE_DIR=

# RAG Store Configuration
INDEX_DIR=data/index
# Source dataset (CSVs) used to (re)build the index
DATA_DIR=data/dataset
# Optional: expected embedding dimension
VECTOR_SIZE=

# RAG Retreival Configuration
TOP_K=4

# Logging Configuration
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# RAG Store Filters
# Keep questions scoring at least this high
MIN_QUESTION_SCORE=5
# Keep answers scoring at least this high
MIN_ANSWER_SCORE=1
# Cap the number of Q&A documents in the index (keeps it small + fast)
MAX_DOCS=50000
